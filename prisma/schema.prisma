generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  STAFF
  CUSTOMER
}

enum DeviceType {
  LAPTOP
  DESKTOP
  PRINTER
  MONITOR
  UPS
  OTHER
}

enum JobStatus {
  RECEIVED
  DIAGNOSED
  IN_PROGRESS
  WAITING_FOR_PARTS
  COMPLETED
  DELIVERED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  FULL
  HALF
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum PaymentMode {
  CASH
  PHONEPE
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchaseStatus {
  RECEIVED
  PARTIAL
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Shop {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String
  email     String?
  createdAt DateTime @default(now())

  users             User[]
  customers         Customer[]
  serviceJobs       ServiceJob[]
  staff             Staff[]
  inventoryItems    InventoryItem[]
  suppliers         Supplier[]
  productCategories ProductCategory[]
  products          Product[]
  purchases         Purchase[]
  sales             Sale[]
}

model User {
  id        String   @id @default(uuid())
  shopId    String
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  shop          Shop           @relation(fields: [shopId], references: [id])
  assignedJobs  ServiceJob[]   @relation("AssignedJobs")
  jobStatusLogs JobStatusLog[]
  staff         Staff?
}

model Customer {
  id        String   @id @default(uuid())
  shopId    String
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())

  shop        Shop         @relation(fields: [shopId], references: [id])
  serviceJobs ServiceJob[]
  sales       Sale[]

  @@unique([shopId, phone])
}

model ServiceJob {
  id              String     @id @default(uuid())
  shopId          String
  customerId      String
  assignedTo      String?
  jobNumber       String
  deviceType      DeviceType
  problemNotes    String?
  internalNotes   String?
  remarks         String?
  estimatedAmount Decimal?   @db.Decimal(10, 2)
  finalAmount     Decimal?   @db.Decimal(10, 2)
  status          JobStatus  @default(RECEIVED)
  isUrgent        Boolean    @default(false)
  warrantyUntil   DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  completedAt     DateTime?

  shop       Shop           @relation(fields: [shopId], references: [id])
  customer   Customer       @relation(fields: [customerId], references: [id])
  assignee   User?          @relation("AssignedJobs", fields: [assignedTo], references: [id])
  statusLogs JobStatusLog[]
  parts      JobPart[]

  @@unique([shopId, jobNumber])
}

model JobStatusLog {
  id        String    @id @default(uuid())
  jobId     String
  changedBy String
  oldStatus JobStatus
  newStatus JobStatus
  notes     String?
  changedAt DateTime  @default(now())

  job  ServiceJob @relation(fields: [jobId], references: [id])
  user User       @relation(fields: [changedBy], references: [id])
}

model Staff {
  id            String   @id @default(uuid())
  userId        String   @unique
  shopId        String
  monthlySalary Decimal  @db.Decimal(10, 2)
  joinedOn      DateTime @default(now())
  isActive      Boolean  @default(true)

  user          User           @relation(fields: [userId], references: [id])
  shop          Shop           @relation(fields: [shopId], references: [id])
  attendance    Attendance[]
  salaryRecords SalaryRecord[]
  leaveRequests LeaveRequest[]
}

model Attendance {
  id      String           @id @default(uuid())
  staffId String
  date    DateTime         @db.Date
  status  AttendanceStatus
  notes   String?

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
}

model SalaryRecord {
  id            String        @id @default(uuid())
  staffId       String
  month         Int
  year          Int
  daysPresent   Decimal       @db.Decimal(4, 1)
  perDayRate    Decimal       @db.Decimal(10, 2)
  totalEarned   Decimal       @db.Decimal(10, 2)
  totalPaid     Decimal       @default(0) @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(PENDING)

  staff    Staff           @relation(fields: [staffId], references: [id])
  payments SalaryPayment[]

  @@unique([staffId, month, year])
}

model SalaryPayment {
  id             String      @id @default(uuid())
  salaryRecordId String
  amount         Decimal     @db.Decimal(10, 2)
  paymentMode    PaymentMode
  paidOn         DateTime    @db.Date
  reference      String?
  notes          String?

  salaryRecord SalaryRecord @relation(fields: [salaryRecordId], references: [id])
}

model InventoryItem {
  id          String   @id @default(uuid())
  shopId      String
  name        String
  description String?
  stock       Int      @default(0)
  minStock    Int      @default(1)
  costPrice   Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id])
  jobParts JobPart[]
}

model JobPart {
  id              String   @id @default(uuid())
  jobId           String
  inventoryItemId String
  quantity        Int
  costAtTime      Decimal  @db.Decimal(10, 2)
  addedAt         DateTime @default(now())

  job  ServiceJob    @relation(fields: [jobId], references: [id])
  item InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

model LeaveRequest {
  id        String      @id @default(uuid())
  staffId   String
  date      DateTime    @db.Date
  type      LeaveType
  reason    String?
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())

  staff Staff @relation(fields: [staffId], references: [id])
}

// ─── Sales Module ─────────────────────────────────────────────────────────────

model Supplier {
  id        String   @id @default(uuid())
  shopId    String
  name      String
  phone     String?
  email     String?
  address   String?
  gstin     String?
  createdAt DateTime @default(now())

  shop      Shop       @relation(fields: [shopId], references: [id])
  purchases Purchase[]
  products  Product[]
}

model ProductCategory {
  id     String @id @default(uuid())
  shopId String
  name   String

  shop     Shop      @relation(fields: [shopId], references: [id])
  products Product[]

  @@unique([shopId, name])
}

model Product {
  id          String   @id @default(uuid())
  shopId      String
  categoryId  String?
  supplierId  String?
  name        String
  description String?
  sku         String?
  costPrice   Decimal  @db.Decimal(10, 2)
  sellPrice   Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  minStock    Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  shop          Shop             @relation(fields: [shopId], references: [id])
  category      ProductCategory? @relation(fields: [categoryId], references: [id])
  supplier      Supplier?        @relation(fields: [supplierId], references: [id])
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@unique([shopId, sku])
}

model Purchase {
  id             String         @id @default(uuid())
  shopId         String
  supplierId     String?
  purchaseNumber String
  status         PurchaseStatus @default(RECEIVED)
  totalAmount    Decimal        @db.Decimal(10, 2)
  notes          String?
  purchasedAt    DateTime       @default(now())
  createdAt      DateTime       @default(now())

  shop     Shop           @relation(fields: [shopId], references: [id])
  supplier Supplier?      @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@unique([shopId, purchaseNumber])
}

model PurchaseItem {
  id         String  @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  costAtTime Decimal @db.Decimal(10, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

model Sale {
  id         String     @id @default(uuid())
  shopId     String
  customerId String?
  saleNumber String
  status     SaleStatus @default(COMPLETED)
  subtotal   Decimal    @db.Decimal(10, 2)
  discount   Decimal    @default(0) @db.Decimal(10, 2)
  tax        Decimal    @default(0) @db.Decimal(10, 2)
  total      Decimal    @db.Decimal(10, 2)
  paymentMode PaymentMode @default(CASH)
  notes      String?
  soldAt     DateTime   @default(now())
  createdAt  DateTime   @default(now())

  shop     Shop       @relation(fields: [shopId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  items    SaleItem[]

  @@unique([shopId, saleNumber])
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String
  quantity    Int
  priceAtTime Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}
